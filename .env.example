MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=cvpr_display
MYSQL_USER=cvpr
MYSQL_PASSWORD=change_me_mysql_password
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DSN=cvpr:change_me_mysql_password@tcp(mysql:3306)/cvpr_display?charset=utf8mb4&parseTime=true&loc=Local

KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC=cvpr.raw.papers

BACKEND_PORT=8080
FRONTEND_PORT=5173
MYSQL_PORT=3306
KAFKA_EXTERNAL_PORT=29092
FLINK_UI_PORT=18082

BINLOG_ENABLED=true
BINLOG_HOST=mysql
BINLOG_PORT=3306
BINLOG_USER=replicator
BINLOG_PASSWORD=change_me_replicator_password
BINLOG_SERVER_ID=2001

# Optional image overrides for slow Docker Hub networks.
MYSQL_IMAGE=mysql:8.4
KAFKA_IMAGE=apache/kafka:3.8.0
FLINK_IMAGE=flink:1.18-java11
MAVEN_IMAGE=maven:3.9-eclipse-temurin-11
NODE_IMAGE=node:20-alpine
NGINX_IMAGE=nginx:1.27-alpine
GO_IMAGE=golang:1.24-alpine
ALPINE_IMAGE=alpine:3.21
PYTHON_IMAGE=python:3.12-slim
